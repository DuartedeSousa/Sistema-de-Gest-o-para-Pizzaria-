# Variáveis de Ambiente

# Porta do server
PORT=3001

# Caminho do arquivo do banco de dados SQLite
# O arquivo será criado de forma automática na primeira execução,
# Lembre-se de deixar em branco para usar o padrão (pizzaria.db na raiz do projeto)
DB_PATH=./pizzaria.db

# Chave secreta do JWT
JWT_SECRET=pizzaria_super_secret_2025

